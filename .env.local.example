# Copy this file to `.env.local` and fill in your Stripe TEST keys.
# Get them from https://dashboard.stripe.com/test/apikeys after signing up.
# The test secret key starts with `sk_test_...`.

STRIPE_SECRET_KEY=sk_test_replace_me

# Optional: used by `npm run generate:deck` / `node scripts/generate-deck-art.mjs`
# As of 2026-04-29, the public Image API docs list GPT image models such as
# `gpt-image-1.5`, `gpt-image-1`, and `gpt-image-1-mini`.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj_replace_me
